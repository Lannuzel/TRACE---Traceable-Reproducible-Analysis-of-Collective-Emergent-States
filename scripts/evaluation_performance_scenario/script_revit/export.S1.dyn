    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import csv\r\n\r\ndata = IN[0]      # liste de lignes (header inclus)\r\npath = IN[1]      # chemin complet vers .csv (string)\r\n\r\nwith open(path, \"w\", newline=\"\", encoding=\"utf-8\") as f:\r\n    writer = csv.writer(f, delimiter=\";\")\r\n    for row in data:\r\n        writer.writerow(row)\r\n\r\nOUT = path\r\n",
